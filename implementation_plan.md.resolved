# Espace Super Admin — Plan d'implémentation

## Base de données — Nouvelles tables

Script SQL à exécuter dans **Supabase SQL Editor** :

```sql
-- 1. Table des formations (remplace le tableau hardcodé)
CREATE TABLE formations (
  id uuid DEFAULT gen_random_uuid() PRIMARY KEY,
  value text UNIQUE NOT NULL,
  label text NOT NULL,
  created_at timestamptz DEFAULT now()
);
ALTER TABLE formations ENABLE ROW LEVEL SECURITY;
DROP POLICY IF EXISTS "Formations visibles par tous" ON formations;
CREATE POLICY "Formations visibles par tous" ON formations FOR SELECT USING (true);
INSERT INTO formations (value, label) VALUES
  ('marketing-digital', 'Marketing Digital'),
  ('digital-creator', 'Digital Creator'),
  ('developpement-web', 'Développement Web');

-- 2. Journal d'audit
CREATE TABLE audit_log (
  id uuid DEFAULT gen_random_uuid() PRIMARY KEY,
  actor_id uuid NOT NULL,
  actor_name text,
  action text NOT NULL,
  target_type text,
  target_id text,
  details jsonb,
  created_at timestamptz DEFAULT now()
);
ALTER TABLE audit_log ENABLE ROW LEVEL SECURITY;
DROP POLICY IF EXISTS "Audit visible par super_admin uniquement" ON audit_log;
CREATE POLICY "Audit visible par super_admin uniquement" ON audit_log FOR SELECT USING (true);

-- 3. Annonces
CREATE TABLE IF NOT EXISTS announcements (
  id uuid DEFAULT gen_random_uuid() PRIMARY KEY,
  author_id uuid NOT NULL,
  author_name text,
  title text NOT NULL,
  message text NOT NULL,
  target_role text DEFAULT 'all',
  created_at timestamptz DEFAULT now()
);
ALTER TABLE announcements ENABLE ROW LEVEL SECURITY;
DROP POLICY IF EXISTS "Annonces visibles par tous" ON announcements;
CREATE POLICY "Annonces visibles par tous" ON announcements FOR SELECT USING (true);

-- 4. Table des PROFILS (pour rendre les infos coaches visibles dans Table Editor)
CREATE TABLE IF NOT EXISTS public.profiles (
  id uuid REFERENCES auth.users ON DELETE CASCADE PRIMARY KEY,
  email text,
  full_name text,
  role text,
  formation text,
  formation_label text,
  created_at timestamptz DEFAULT now()
);
ALTER TABLE public.profiles ENABLE ROW LEVEL SECURITY;
DROP POLICY IF EXISTS "Profils visibles par tous" ON public.profiles;
CREATE POLICY "Profils visibles par tous" ON public.profiles FOR SELECT USING (auth.role() = 'authenticated');

-- Trigger pour synchroniser auto depuis auth.users
CREATE OR REPLACE FUNCTION public.handle_new_user()
RETURNS trigger AS $$
BEGIN
  INSERT INTO public.profiles (id, email, full_name, role, formation, formation_label)
  VALUES (
    new.id,
    new.email,
    new.raw_user_meta_data->>'full_name',
    new.raw_user_meta_data->>'role',
    new.raw_user_meta_data->>'formation',
    new.raw_user_meta_data->>'formation_label'
  );
  RETURN new;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

DROP TRIGGER IF EXISTS on_auth_user_created ON auth.users;
CREATE TRIGGER on_auth_user_created
  AFTER INSERT ON auth.users
  FOR EACH ROW EXECUTE FUNCTION public.handle_new_user();
```

